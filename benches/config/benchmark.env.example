# Copy to benches/config/benchmark.env or export these variables before running.

DATA_ROOT="benches/data"
RUNS_ROOT="benches/runs"

# Number of paired reads retained from each ENA run for benchmark inputs.
READ_PAIRS="100000"

# Repeated timed runs per tool/dataset.
REPLICATES="3"

# Thread count passed to tools with explicit thread controls.
THREADS="8"

# plain avoids benchmarking gzip compression by default; gzip is useful when
# release workflows need compressed merged outputs.
OUTPUT_COMPRESSION="plain"
